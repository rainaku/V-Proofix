<Window x:Class="VProofix.Views.PreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="V-Proofix Preview" Height="250" Width="400"
        WindowStyle="None" Topmost="True" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent"
        PreviewKeyDown="Window_PreviewKeyDown"
        WindowStartupLocation="CenterScreen">
    
    <Border Background="White" CornerRadius="8" Margin="10" Padding="15" RenderTransformOrigin="0.5,0.5" Opacity="0">
        <Border.RenderTransform>
            <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
        </Border.RenderTransform>
        <Border.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.15">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="0.9" To="1" Duration="0:0:0.25">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="0.9" To="1" Duration="0:0:0.25">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Border.Triggers>
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.2" Color="Black"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Preview &amp; Review" FontWeight="Bold" FontSize="14" Margin="0,0,0,10" Foreground="#333333"/>
            
            <TextBox x:Name="txtPreview" Grid.Row="1" TextWrapping="Wrap" AcceptsReturn="True" 
                     VerticalScrollBarVisibility="Auto" Background="#F9F9F9" Padding="5" 
                     BorderBrush="#DDDDDD" FontSize="14" Foreground="#444444" IsReadOnly="False"/>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button Content="Copy (Ctrl+C)" Width="100" Margin="0,0,10,0" Padding="5" Click="Copy_Click" Background="#E0E0E0"/>
                <Button Content="Replace (Enter)" Width="110" Padding="5" Click="Replace_Click" Background="#007ACC" Foreground="White" BorderBrush="Transparent"/>
            </StackPanel>
            
            <Button FlowDirection="RightToLeft" Content="✕" Width="20" Height="20" HorizontalAlignment="Right" VerticalAlignment="Top" 
                    Background="Transparent" BorderThickness="0" Foreground="Gray" Click="Cancel_Click" ToolTip="Close (Esc)"/>
        </Grid>
    </Border>
</Window>
