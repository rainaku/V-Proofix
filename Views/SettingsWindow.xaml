<Window x:Class="VProofix.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="V-Proofix Settings" Height="480" Width="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F4F4F9" Opacity="0">
    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.15">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock x:Name="lblApiKey" Text="Gemini API Key:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,5"/>
        <PasswordBox x:Name="txtApiKey" Grid.Row="0" Grid.Column="1" Margin="0,5" Padding="5"/>

        <TextBlock x:Name="lblModelName" Text="Model Name:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,5"/>
        <ComboBox x:Name="cmbModelName" Grid.Row="1" Grid.Column="1" Margin="0,5" Padding="5" IsEditable="False">
            <ComboBoxItem Content="gemini-2.5-flash"/>
            <ComboBoxItem Content="gemini-2.5-pro"/>
            <ComboBoxItem Content="gemini-2.0-flash"/>
            <ComboBoxItem Content="gemini-2.0-flash-exp"/>
            <ComboBoxItem Content="gemini-2.0-flash-lite"/>
            <ComboBoxItem Content="gemini-2.5-flash-tts"/>
            <ComboBoxItem Content="gemini-2.5-pro-tts"/>
            <ComboBoxItem Content="gemma-3-27b-it"/>
            <ComboBoxItem Content="gemma-3-12b-it"/>
            <ComboBoxItem Content="gemma-3-4b-it"/>
            <ComboBoxItem Content="gemma-3-1b-it"/>
        </ComboBox>

        <TextBlock x:Name="lblAppLanguage" Text="UI Language:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,5"/>
        <ComboBox x:Name="cmbAppLanguage" Grid.Row="2" Grid.Column="1" Margin="0,5" Padding="5">
            <ComboBoxItem Content="English"/>
            <ComboBoxItem Content="Vietnamese"/>
        </ComboBox>

        <TextBlock x:Name="lblTargetLanguage" Text="Target Language:" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,5"/>
        <ComboBox x:Name="cmbTargetLanguage" Grid.Row="3" Grid.Column="1" Margin="0,5" Padding="5">
            <ComboBoxItem Content="Auto"/>
            <ComboBoxItem Content="English"/>
            <ComboBoxItem Content="Vietnamese"/>
        </ComboBox>

        <TextBlock x:Name="lblFixHotkey" Text="Fix Hotkey:" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Margin="0,5"/>
        <TextBox x:Name="txtFixHotkey" Grid.Row="4" Grid.Column="1" Margin="0,5" Padding="5"/>

        <TextBlock x:Name="lblPreviewHotkey" Text="Preview Hotkey:" Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Margin="0,5"/>
        <TextBox x:Name="txtPreviewHotkey" Grid.Row="5" Grid.Column="1" Margin="0,5" Padding="5"/>

        <TextBlock x:Name="lblPromptFormat" Text="Prompt Format:" Grid.Row="6" Grid.Column="0" VerticalAlignment="Top" Margin="0,5"/>
        <TextBox x:Name="txtPromptFormat" Grid.Row="6" Grid.Column="1" Margin="0,5" Padding="5" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>

        <!-- Checks -->
        <CheckBox x:Name="chkShowPreview" Content="Show Preview window before replacing (Optional)" Grid.Row="7" Grid.Column="1" Margin="0,10,0,5"/>
        <CheckBox x:Name="chkPrivacyMode" Content="Privacy Mode (Do not save history)" Grid.Row="8" Grid.Column="1" Margin="0,5,0,10"/>

        <!-- Action -->
        <StackPanel Grid.Row="10" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,15,0,0">
            <Button x:Name="btnExit" Content="Exit App" Width="80" Margin="0,0,10,0" Padding="5" Click="ExitApp_Click" Background="#FF4C4C" Foreground="White" BorderBrush="Transparent"/>
            <Button x:Name="btnCancel" Content="Cancel" Width="80" Margin="0,0,10,0" Padding="5" Click="Cancel_Click" Background="#E0E0E0"/>
            <Button x:Name="btnSave" Content="Save" Width="80" Padding="5" Click="Save_Click" Background="#007ACC" Foreground="White" BorderBrush="Transparent"/>
        </StackPanel>
    </Grid>
</Window>
