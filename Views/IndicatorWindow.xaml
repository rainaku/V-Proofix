<Window x:Class="VProofix.Views.IndicatorWindow"
        x:Name="IndicatorWin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Working" Width="300" Height="200"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" WindowStartupLocation="CenterScreen" 
        Focusable="False" IsHitTestVisible="False" ShowActivated="False">
    <Window.Resources>
        <!-- Fade Out and Scale Down for closing -->
        <Storyboard x:Key="WindowCloseAnimation">
            <DoubleAnimation Storyboard.TargetName="IndicatorWin" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="MainBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="0.85" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="MainBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="0.85" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Spinner to Checkmark Morph -->
        <Storyboard x:Key="SuccessAnimation">
            <!-- Fade out Spinner -->
            <DoubleAnimation Storyboard.TargetName="SpinnerContainer" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15" />
            <DoubleAnimation Storyboard.TargetName="SpinnerContainer" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="0.5" Duration="0:0:0.15" />
            <DoubleAnimation Storyboard.TargetName="SpinnerContainer" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="0.5" Duration="0:0:0.15" />
            
            <!-- Fade in Checkmark -->
            <DoubleAnimation Storyboard.TargetName="CheckmarkPath" Storyboard.TargetProperty="Opacity" To="1" BeginTime="0:0:0.1" Duration="0:0:0.2" />
            <DoubleAnimation Storyboard.TargetName="CheckmarkContainer" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="0.5" To="1" BeginTime="0:0:0.1" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <ElasticEase EasingMode="EaseOut" Oscillations="1" Springiness="4"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CheckmarkContainer" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="0.5" To="1" BeginTime="0:0:0.1" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <ElasticEase EasingMode="EaseOut" Oscillations="1" Springiness="4"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            
            <!-- Hide Text or Change it if needed, we'll let code-behind change text if desired, but we'll leave it generally -->
        </Storyboard>
    </Window.Resources>

    <Grid>
        <Border x:Name="MainBorder" Background="#26FFFFFF" CornerRadius="20" RenderTransformOrigin="0.5,0.5" Opacity="0" ClipToBounds="True">
            <Border.RenderTransform>
                <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
            </Border.RenderTransform>
            <Border.Effect>
                <!-- Subtle dropping shadow, not too dark -->
                <DropShadowEffect Color="Black" BlurRadius="30" Opacity="0.15" ShadowDepth="10" Direction="270"/>
            </Border.Effect>
            <Border.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="0.9" To="1" Duration="0:0:0.4">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="0.9" To="1" Duration="0:0:0.4">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Border.Triggers>

            <Grid>
                <!-- Liquid Blur Backing/Distortion -->
                <Grid x:Name="LiquidContainer" Opacity="0.7">
                    <!-- Layer 1 -->
                    <Ellipse Margin="-50,-50,50,50" Width="400" Height="300" HorizontalAlignment="Left" VerticalAlignment="Top">
                        <Ellipse.Fill>
                            <RadialGradientBrush x:Name="LiquidBlob1" Center="0.2,0.3" GradientOrigin="0.2,0.3" RadiusX="0.8" RadiusY="0.8">
                                <GradientStop Color="#1AFFFFFF" Offset="0" />
                                <GradientStop Color="#00FFFFFF" Offset="1" />
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                        <!-- Fluid animation -->
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard AutoReverse="True" RepeatBehavior="Forever">
                                        <PointAnimation Storyboard.TargetName="LiquidBlob1" Storyboard.TargetProperty="Center" To="0.8,0.7" Duration="0:0:7" >
                                            <PointAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseInOut"/>
                                            </PointAnimation.EasingFunction>
                                        </PointAnimation>
                                        <PointAnimation Storyboard.TargetName="LiquidBlob1" Storyboard.TargetProperty="GradientOrigin" To="0.8,0.7" Duration="0:0:7" >
                                            <PointAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseInOut"/>
                                            </PointAnimation.EasingFunction>
                                        </PointAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                    
                    <!-- Layer 2 -->
                    <Ellipse Margin="50,50,-50,-50" Width="400" Height="300" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                        <Ellipse.Fill>
                            <RadialGradientBrush x:Name="LiquidBlob2" Center="0.8,0.7" GradientOrigin="0.8,0.7" RadiusX="0.8" RadiusY="0.8">
                                <GradientStop Color="#10FFFFFF" Offset="0" />
                                <GradientStop Color="#00FFFFFF" Offset="1" />
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard AutoReverse="True" RepeatBehavior="Forever">
                                        <PointAnimation Storyboard.TargetName="LiquidBlob2" Storyboard.TargetProperty="Center" To="0.2,0.3" Duration="0:0:9" >
                                            <PointAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseInOut"/>
                                            </PointAnimation.EasingFunction>
                                        </PointAnimation>
                                        <PointAnimation Storyboard.TargetName="LiquidBlob2" Storyboard.TargetProperty="GradientOrigin" To="0.2,0.3" Duration="0:0:9" >
                                            <PointAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseInOut"/>
                                            </PointAnimation.EasingFunction>
                                        </PointAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                </Grid>

                <!-- Specular Highlight Borders (Inner and Outer Edge Highlights) -->
                <!-- Base white shine inside the borders mimicking inset shadow -->
                <Border BorderBrush="#60FFFFFF" BorderThickness="1.5" CornerRadius="20" />
                <Border BorderBrush="#20FFFFFF" BorderThickness="1" CornerRadius="20" Margin="1.5" />

                <!-- Content -->
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
                    <!-- Animation Container -->
                    <Grid Width="50" Height="50" HorizontalAlignment="Center">
                        
                        <!-- Spinner Container -->
                        <Grid x:Name="SpinnerContainer" RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Grid.RenderTransform>
                            <!-- Spinner Background -->
                            <Ellipse Stroke="#20000000" StrokeThickness="4" />
                            <!-- Spinner Arc -->
                            <Path x:Name="SpinnerArc" Data="M 25 2 A 23 23 0 0 1 48 25" Stroke="#444444" StrokeThickness="4" StrokeStartLineCap="Round" StrokeEndLineCap="Round" RenderTransformOrigin="0.5,0.5">
                                <Path.RenderTransform>
                                    <RotateTransform x:Name="SpinnerTransform" Angle="0"/>
                                </Path.RenderTransform>
                                <Path.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="SpinnerTransform"
                                                                 Storyboard.TargetProperty="Angle"
                                                                 From="0" To="360" Duration="0:0:1"
                                                                 RepeatBehavior="Forever" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Path.Triggers>
                            </Path>
                        </Grid>

                        <!-- Checkmark Container (Initially Transparent and Scaled Down) -->
                        <Grid x:Name="CheckmarkContainer" RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <ScaleTransform ScaleX="0.5" ScaleY="0.5"/>
                            </Grid.RenderTransform>
                            <!-- Apple Green Checkmark -->
                            <Path x:Name="CheckmarkPath" Data="M 12,25 L 22,35 L 38,15" Stroke="#34C759" StrokeThickness="4" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Opacity="0" />
                        </Grid>
                    </Grid>
                    
                    <!-- Text Description -->
                    <TextBlock x:Name="txtStatus" Text="V-Proofix đang làm việc, xin bạn vui lòng chờ và không chuyển cửa sổ" Foreground="#333333" FontWeight="SemiBold" FontSize="14" Margin="0,20,0,0" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="240" Opacity="0.95">
                        <TextBlock.Effect>
                            <!-- Soft drop shadow for dark text on glass -->
                            <DropShadowEffect Color="White" BlurRadius="2" Opacity="0.8" ShadowDepth="1" Direction="270" />
                        </TextBlock.Effect>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
