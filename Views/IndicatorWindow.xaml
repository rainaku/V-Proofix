<Window x:Class="VProofix.Views.IndicatorWindow"
        x:Name="IndicatorWin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Working" Width="340" Height="240"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" WindowStartupLocation="CenterScreen" 
        Focusable="False" IsHitTestVisible="False" ShowActivated="False">
    <Window.Resources>
        <!-- Fade Out and Scale Down for closing -->
        <Storyboard x:Key="WindowCloseAnimation">
            <DoubleAnimation Storyboard.TargetName="IndicatorWin" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="MainBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="0.85" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="MainBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="0.85" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Spinner to Checkmark Morph -->
        <Storyboard x:Key="SuccessAnimation">
            <DoubleAnimation Storyboard.TargetName="SpinnerContainer" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15" />
            <DoubleAnimation Storyboard.TargetName="CheckmarkPath" Storyboard.TargetProperty="Opacity" To="1" BeginTime="0:0:0.1" Duration="0:0:0.2" />
            <DoubleAnimation Storyboard.TargetName="CheckmarkContainer" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="0.5" To="1" BeginTime="0:0:0.1" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <ElasticEase EasingMode="EaseOut" Oscillations="1" Springiness="4"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CheckmarkContainer" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="0.5" To="1" BeginTime="0:0:0.1" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <ElasticEase EasingMode="EaseOut" Oscillations="1" Springiness="4"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Spinner to Error -->
        <Storyboard x:Key="ErrorAnimation">
            <DoubleAnimation Storyboard.TargetName="SpinnerContainer" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15" />
            <DoubleAnimation Storyboard.TargetName="ErrorContainer" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.2" />
            <DoubleAnimation Storyboard.TargetName="ErrorContainer" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="0.5" To="1" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <BackEase EasingMode="EaseOut" Amplitude="1"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ErrorContainer" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="0.5" To="1" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <BackEase EasingMode="EaseOut" Amplitude="1"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Grid Margin="30"> <!-- Increased margin for larger shadow spread -->
        <Border x:Name="MainBorder" Background="White" CornerRadius="22" RenderTransformOrigin="0.5,0.5" Opacity="0" SnapsToDevicePixels="True" UseLayoutRounding="True">
            <Border.Effect>
                <!-- Even shadow 'xung quanh' as requested -->
                <DropShadowEffect Color="Black" BlurRadius="25" Opacity="0.15" ShadowDepth="0"/>
            </Border.Effect>
            <Border.RenderTransform>
                <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
            </Border.RenderTransform>
            <Border.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="0.9" To="1" Duration="0:0:0.4">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="0.9" To="1" Duration="0:0:0.4">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Border.Triggers>

            <Grid>
                <!-- Content -->
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="25">
                    <!-- Animation Container -->
                    <Grid Width="60" Height="60" HorizontalAlignment="Center">
                        
                        <!-- Spinner Container -->
                        <Grid x:Name="SpinnerContainer" RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Grid.RenderTransform>
                            <!-- Spinner Background -->
                            <Ellipse Stroke="#F0F0F0" StrokeThickness="5" />
                            <!-- Spinner Arc -->
                            <Path x:Name="SpinnerArc" Data="M 30 2 A 28 28 0 0 1 58 30" Stroke="#007AFF" StrokeThickness="5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" RenderTransformOrigin="0.5,0.5">
                                <Path.Effect>
                                    <DropShadowEffect Color="#007AFF" BlurRadius="12" Opacity="0.75" ShadowDepth="0" Direction="0"/>
                                </Path.Effect>
                                <Path.RenderTransform>
                                    <RotateTransform x:Name="SpinnerTransform" Angle="0"/>
                                </Path.RenderTransform>
                                <Path.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="SpinnerTransform"
                                                                 Storyboard.TargetProperty="Angle"
                                                                 From="0" To="360" Duration="0:0:1"
                                                                 RepeatBehavior="Forever" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Path.Triggers>
                            </Path>
                        </Grid>

                        <!-- Checkmark Container -->
                        <Grid x:Name="CheckmarkContainer" RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <ScaleTransform ScaleX="0.5" ScaleY="0.5"/>
                            </Grid.RenderTransform>
                            <Path x:Name="CheckmarkPath" Data="M 15,30 L 27,42 L 45,18" Stroke="#007AFF" StrokeThickness="5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Opacity="0">
                                <Path.Effect>
                                    <DropShadowEffect Color="#007AFF" BlurRadius="12" Opacity="0.75" ShadowDepth="0" Direction="0"/>
                                </Path.Effect>
                            </Path>
                        </Grid>

                        <!-- Error Container (Initially Transparent) -->
                        <Grid x:Name="ErrorContainer" RenderTransformOrigin="0.5,0.5" Opacity="0">
                            <Grid.RenderTransform>
                                <ScaleTransform ScaleX="0.5" ScaleY="0.5"/>
                            </Grid.RenderTransform>
                            <!-- Red X Icon -->
                            <Path Data="M 18,18 L 42,42 M 42,18 L 18,42" Stroke="#007AFF" StrokeThickness="5" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                <Path.Effect>
                                    <DropShadowEffect Color="#007AFF" BlurRadius="12" Opacity="0.75" ShadowDepth="0" Direction="0"/>
                                </Path.Effect>
                            </Path>
                        </Grid>
                    </Grid>
                    
                    <!-- Text Description -->
                    <TextBlock x:Name="txtStatus" 
                               Text="V-Proofix đang làm việc..." 
                               Foreground="#007AFF" 
                               FontWeight="Bold" 
                               FontSize="16" 
                               Margin="0,25,0,0" 
                               HorizontalAlignment="Center" 
                               TextAlignment="Center" 
                               TextWrapping="Wrap" 
                               MaxWidth="260">
                        <TextBlock.Effect>
                            <!-- Blue glow for text -->
                            <DropShadowEffect Color="#007AFF" BlurRadius="12" Opacity="0.75" ShadowDepth="0" Direction="0" />
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock x:Name="txtSubStatus" 
                               Text="Khởi tạo..." 
                               Foreground="#007AFF" 
                               FontWeight="SemiBold"
                               FontSize="12" 
                               Margin="0,6,0,0" 
                               HorizontalAlignment="Center" 
                               TextAlignment="Center" 
                               TextWrapping="Wrap" 
                               MaxWidth="260">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#007AFF" BlurRadius="10" Opacity="0.6" ShadowDepth="0" Direction="0" />
                        </TextBlock.Effect>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
