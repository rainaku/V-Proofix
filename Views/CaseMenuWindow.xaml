<Window x:Class="VProofix.Views.CaseMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Change Case" Width="220" Height="230"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" WindowStartupLocation="CenterScreen"
        Deactivated="Window_Deactivated" KeyDown="Window_KeyDown" Loaded="Window_Loaded">
    <Window.Resources>
        <!-- Fade In Animation -->
        <Storyboard x:Key="WindowOpenAnimation">
            <DoubleAnimation Storyboard.TargetName="MainBorder" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.15">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="MainBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="0.9" To="1" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="MainBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="0.9" To="1" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        
        <!-- Hover Style for Buttons -->
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <TextBlock Text="{TemplateBinding Content}" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F0F0"/>
                    <Setter Property="Foreground" Value="#007AFF"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="Background" Value="#E5F1FF"/>
                    <Setter Property="Foreground" Value="#007AFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Border x:Name="MainBorder" Background="White" CornerRadius="12" RenderTransformOrigin="0.5,0.5" Opacity="0">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="15" Opacity="0.15" ShadowDepth="2" Direction="270"/>
            </Border.Effect>
            <Border.RenderTransform>
                <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
            </Border.RenderTransform>
            <Border.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard Storyboard="{StaticResource WindowOpenAnimation}"/>
                </EventTrigger>
            </Border.Triggers>

            <StackPanel Margin="8" x:Name="ButtonPanel">
                <TextBlock Text="Change Case" FontWeight="Bold" Foreground="#888888" FontSize="11" Margin="10,5,10,10" />
                
                <Button Content="U - UPPERCASE" Style="{StaticResource MenuButtonStyle}" Click="BtnUpper_Click" Tag="UPPER"/>
                <Button Content="D - lowercase" Style="{StaticResource MenuButtonStyle}" Click="BtnLower_Click" Tag="LOWER"/>
                <Button Content="C - Capitalize" Style="{StaticResource MenuButtonStyle}" Click="BtnCapitalize_Click" Tag="CAPITAL"/>
                <Button Content="S - Sentence case" Style="{StaticResource MenuButtonStyle}" Click="BtnSentence_Click" Tag="SENTENCE"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
